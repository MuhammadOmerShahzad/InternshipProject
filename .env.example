# Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# AWS RDS POSTGRESQL
# ===========================================

# Full PostgreSQL connection string (recommended)
DATABASE_URL=postgresql://<username>:<password>@<rds-endpoint>:5432/<dbname>?sslmode=require

# Individual fields (optional alternative)
# DB_HOST=<rds-endpoint>
# DB_PORT=5432
# DB_USER=<username>
# DB_PASSWORD=<password>
# DB_NAME=<dbname>

# ===========================================
# APP CONFIGURATION
# ===========================================

NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Environment indicator
# NODE_ENV=development

# ===========================================
# CI/CD SECRETS (Configure in GitHub Settings)
# ===========================================
# These are NOT set here - configure in GitHub > Settings > Secrets:
#
# DATABASE_URL              - Full RDS PostgreSQL connection string
# VERCEL_TOKEN              - Vercel authentication token
# VERCEL_ORG_ID             - Your Vercel organization ID
# VERCEL_PROJECT_ID         - Your Vercel project ID
