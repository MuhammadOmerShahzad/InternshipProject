# Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================

# Public Supabase URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url

# Public Supabase Anonymous Key (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service Role Key (KEEP SECRET - only for server-side operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================

# Environment indicator
# NODE_ENV=development

# ===========================================
# CI/CD SECRETS (Configure in GitHub Settings)
# ===========================================
# These are NOT set here - configure in GitHub > Settings > Secrets:
#
# VERCEL_TOKEN - Vercel authentication token
# VERCEL_ORG_ID - Your Vercel organization ID
# VERCEL_PROJECT_ID - Your Vercel project ID
# SUPABASE_PROJECT_ID - Your Supabase project reference
# SUPABASE_ACCESS_TOKEN - Supabase CLI access token
# SUPABASE_DB_PASSWORD - Supabase database password
